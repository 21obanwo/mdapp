(if: $gold >= 6)[
  (set: $gold to $gold - 6)
  (set: $health to (min: 100, $health + 10))
  "Here you go!"
]
(else)[
  "Not enough gold, friend."
]

[[Buy Hearty Soup (8 gp)]]
[[Buy Pastry (4 gp)]]
[[Return to Market Street]]

