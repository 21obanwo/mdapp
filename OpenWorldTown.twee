    (set: $gold to $gold - 10)
    (set: $inventory to $inventory + (a: "Rope Coil"))
    Garrett nods approvingly. "Good choice. That'll come in handy."
  ]
  (else)[
    "You already have that item."
  ]
]
(else)[
  "Not enough gold, friend."
]

[[Buy Mysterious Map (25 gp)]]
[[Buy Healing Potion (15 gp)]]
[[Buy Lantern (20 gp)]]
[[Leave the General Shop]]

