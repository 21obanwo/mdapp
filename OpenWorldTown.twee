  (set: $inventory to (a:))
  (set: $questLog to (a:))
  (set: $completedQuests to (a:))
  
  (set: $strength to 5)
  (set: $agility to 5)
  (set: $intelligence to 5)
  (set: $defense to 5)
  (set: $experience to 0)
  (set: $level to 1)
  
  (set: $currentWeapon to "Wooden Sword")
  (set: $currentArmor to "Leather Jacket")
  
  (set: $followers to (a:))
  (set: $followerCount to 0)
  (set: $playerArmy to 0)
  
  (set: $bakerMet to false)
  (set: $guardWarned to false)
